# Ethereum Sepolia RPC (Zama FHEVM coprocessor network). SKALE is no longer used.
NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Obscura protocol addresses (paste from `npm run deploy` output)
NEXT_PUBLIC_CORE=
NEXT_PUBLIC_LENDING=
NEXT_PUBLIC_LP=
NEXT_PUBLIC_GAD=
NEXT_PUBLIC_REPUTATION=
NEXT_PUBLIC_X402=
NEXT_PUBLIC_FLASH=

# Confidential ERC-7984 tokens. Defaults (in code) use the official Sepolia cTokenMocks;
# override here if you deploy your own ConfidentialMockToken set.
NEXT_PUBLIC_USDC=
NEXT_PUBLIC_WETH=
NEXT_PUBLIC_WBTC=
